<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.card.MaterialCardView
         android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:backgroundTint="@color/emphasis_color"

        >
        <androidx.constraintlayout.widget.ConstraintLayout
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            >
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:text="@{jobCard.toString()}"
                android:id="@+id/message"
                />
            <com.google.android.material.textview.MaterialTextView
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/message"
                app:layout_constraintStart_toStartOf="parent"
                android:textColor="@color/white"
                android:text="@{`JobCardNo: `+ jobCard.jobCardNo}"
                app:layout_constraintBottom_toTopOf="@+id/total_containers"
                android:layout_marginBottom="10dp"
                />
            <com.google.android.material.textview.MaterialTextView
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toTopOf="@id/sep_sec2"
                android:id="@+id/total_containers"
                android:text="@{`Total Containers: `+ jobCard.totalContainers}"
                android:layout_marginBottom="5dp"
                />
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="@id/total_containers"
                app:layout_constraintBottom_toBottomOf="@id/total_containers"
                app:layout_constraintEnd_toEndOf="parent"
                android:textColor="@color/white"
                android:text="@{`Still To Collect : `+ jobCard.pendingContainers}"
                />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:background="@color/white"
                android:visibility="gone"
                android:id="@+id/sep_sec2"
                app:layout_constraintBottom_toTopOf="@id/driver_on_jobcard"
                />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/driver_on_jobcard"
                style="@style/save_btn_outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableLeft="@drawable/ic_my_profile"
                android:visibility="gone"
                android:padding="5dp"
                android:text="@string/drivers"
                android:textAllCaps="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
    <data>
        <variable
            name="jobCard"
            type="com.pet001kambala.namopscontainers.model.JobCard" />
    </data>
</layout>
